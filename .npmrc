# Versões exatas sem ^ ou ~
save-exact=true

# Registry oficial fixo — impede redirect para mirror comprometido
registry=https://registry.npmjs.org/

# Audit automático em todo npm install
audit=true
audit-level=high

# Bloqueia scripts de ciclo de vida de pacotes (preinstall, postinstall)
# Principal vetor de supply chain attack (ex: event-stream, ua-parser-js)
ignore-scripts=true

# Bloqueia npm ci/install se Node.js ou npm não atender ao campo `engines` do package.json
engine-strict=true

# Instalação com lockfile congelado é garantida pelo uso de `npm ci` nos scripts
# (setup, npm-reinstall). O npm ci falha automaticamente se package-lock.json
# divergir do package.json — não é necessária configuração adicional aqui.
# NOTA: `prefer-frozen-lockfile` é uma opção do pnpm, não do npm.
